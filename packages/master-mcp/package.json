{
  "name": "ccrelay-master",
  "version": "0.1.0",
  "type": "module",
  "bin": {
    "ccrelay-master": "dist/index.js"
  },
  "main": "dist/index.js",
  "scripts": {
    "build": "tsup src/index.ts --format esm --clean && printf '#!/usr/bin/env node\\n' | cat - dist/index.js > dist/tmp && mv dist/tmp dist/index.js",
    "dev": "tsx src/index.ts"
  },
  "dependencies": {
    "@ccrelay/shared": "*",
    "@modelcontextprotocol/sdk": "^1.12.1",
    "ws": "^8.18.0",
    "zod": "^3.24.0"
  },
  "devDependencies": {
    "@types/ws": "^8.5.13",
    "tsup": "^8.0.0",
    "tsx": "^4.19.0",
    "typescript": "^5.7.0"
  }
}
