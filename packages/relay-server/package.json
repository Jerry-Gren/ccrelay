{
  "name": "ccrelay-server",
  "version": "0.1.0",
  "type": "module",
  "bin": {
    "ccrelay-server": "dist/index.js"
  },
  "main": "dist/index.js",
  "scripts": {
    "build": "tsup src/index.ts --format esm --clean && printf '#!/usr/bin/env node\\n' | cat - dist/index.js > dist/tmp && mv dist/tmp dist/index.js",
    "dev": "tsx src/index.ts",
    "start": "node dist/index.js"
  },
  "dependencies": {
    "@ccrelay/shared": "*",
    "better-sqlite3": "^11.8.1",
    "hono": "^4.12.3",
    "ws": "^8.18.0"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.12",
    "@types/ws": "^8.5.13",
    "tsup": "^8.0.0",
    "tsx": "^4.19.0",
    "typescript": "^5.7.0"
  }
}
